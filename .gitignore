# Allowlist model — this repo tracks only the trial's lean working set:
# CLAUDE.md, WORKSPACE.md, the offline benchmark (trial/harness/) + its tracked
# comparison figures (trial/results/figures/), the /dimensional page source (site/),
# and office_markers.yaml (kept: dimos' go2 blueprint resolves that bare name — see
# its header comment). The cut real-life benchmark's instruments (trial/scripts/),
# the synthetic demo harness (demo/), and the tag PDFs (print/) were removed in the
# Jul 17 cleanup — all in git history ≤ 90c494a. Everything else (spec docs, research
# notes, day-by-day roadmap, PR drafts, page copy, personal logistics, credentials)
# stays on disk, untracked — folded into WORKSPACE.md where still load-bearing.
# See WORKSPACE.md §1 "Where everything lives".

# dimos is its own git repo (cloned separately) — never track as content here
dimos/

# ignore everything by default, then allowlist back in
/*
!/.gitignore
!/CLAUDE.md
!/WORKSPACE.md
!/README.md
!/trial
!/office_markers.yaml
!/site

# trial/ — only the offline benchmark (trial/harness) + tracked figures, nothing else
/trial/*
!/trial/harness

# trial/harness — the offline confidence benchmark (sections harness); out/ stays untracked
/trial/harness/*
!/trial/harness/*.py
!/trial/harness/*.md
!/trial/harness/*.yaml
!/trial/harness/*.sh
!/trial/harness/tests
/trial/harness/tests/*
!/trial/harness/tests/*.py
/trial/harness/out/

# python
**/__pycache__/
*.pyc
.pytest_cache/

# os
.DS_Store

# secrets — never belongs in git history even privately
credentials.md

# trial/results — raw run output stays untracked; comparison FIGURES are tracked
# (visual proof shared between machines — CUDA queue task 6)
!/trial/results
/trial/results/*
!/trial/results/figures
/trial/results/figures/*
!/trial/results/figures/*.png

# site/ — the /dimensional page source + assets (canonical copy; deploys from the portfolio repo)
/site/*
!/site/*.tsx
!/site/*.ts
!/site/assets
/site/assets/*
!/site/assets/*.png
!/site/assets/*.gif
!/site/assets/flow
/site/assets/flow/*
!/site/assets/flow/*.png
