# Allowlist model — this repo tracks only the trial's lean working set:
# CLAUDE.md, WORKSPACE.md, the benchmark instruments (trial/scripts/), the
# synthetic proof harness (demo/), the physical marker kit (print/, office_markers.yaml).
# Everything else (spec docs, research notes, day-by-day roadmap, PR drafts, page
# copy, personal logistics, credentials) stays on disk, untracked — folded into
# WORKSPACE.md where still load-bearing. See WORKSPACE.md §1 "Where everything lives".

# dimos is its own git repo (cloned separately) — never track as content here
dimos/

# ignore everything by default, then allowlist back in
/*
!/.gitignore
!/CLAUDE.md
!/WORKSPACE.md
!/README.md
!/trial
!/office_markers.yaml
!/site

# trial/ — only the offline benchmark (trial/harness) + tracked figures, nothing else
/trial/*
!/trial/harness

# trial/harness — the offline confidence benchmark (sections harness); out/ stays untracked
/trial/harness/*
!/trial/harness/*.py
!/trial/harness/*.md
!/trial/harness/*.yaml
!/trial/harness/*.sh
!/trial/harness/tests
/trial/harness/tests/*
!/trial/harness/tests/*.py
/trial/harness/out/

# python
**/__pycache__/
*.pyc
.pytest_cache/

# os
.DS_Store

# secrets — never belongs in git history even privately
credentials.md

# trial/results — raw run output stays untracked; comparison FIGURES are tracked
# (visual proof shared between machines — CUDA queue task 6)
!/trial/results
/trial/results/*
!/trial/results/figures
/trial/results/figures/*
!/trial/results/figures/*.png

# site/ — the /dimensional page source + assets (canonical copy; deploys from the portfolio repo)
/site/*
!/site/*.tsx
!/site/*.ts
!/site/assets
/site/assets/*
!/site/assets/*.png
!/site/assets/*.gif
!/site/assets/flow
/site/assets/flow/*
!/site/assets/flow/*.png
